{
    "name": "marko/routing",
    "description": "Marko Framework Routing",
    "license": "MIT",
    "type": "library",
    "repositories": [
        {
            "type": "path",
            "url": "../core"
        }
    ],
    "require": {
        "php": "^8.5",
        "marko/core": "@dev"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Routing\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Routing\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
